rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Practices collection
    match /practices/{document=**} {
      // Authenticated admins can read and write
      allow read, write: if request.auth != null;
      // Anyone can create (sign-up form) but not read/update/delete
      allow create: if true;
    }

    // Medications collection: anyone can read (patient view), admin can write
    match /medications/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Administrators collection: admin only
    match /admins/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Protocols collection: admin only
    match /protocols/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
